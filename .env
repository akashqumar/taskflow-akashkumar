# Database — Docker Compose uses service name "postgres" as host
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_secret
POSTGRES_DB=taskflow
DATABASE_URL=postgres://taskflow:taskflow_secret@postgres:5432/taskflow?sslmode=disable

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production-min-32-chars

# Backend
PORT=8080

# Frontend
VITE_API_URL=http://localhost:8080
